def show_hsv_channels(path):
    img = io.imread(path)
    hsv = color.rgb2hsv(img)
    
    hue = hsv[:, :, 0]
    saturation = hsv[:, :, 1]
    value = hsv[:, :, 2]
    
    fig, axes = plt.subplots(1, 4, figsize=(20, 5))
    axes[0].imshow(img)
    axes[0].set_title("Original RGB")
    axes[0].axis("off")
    axes[1].imshow(hue, cmap='hsv')
    axes[1].set_title("Hue Channel")
    axes[1].axis("off")
    axes[2].imshow(saturation, cmap='gray')
    axes[2].set_title("Saturation Channel")
    axes[2].axis("off")
    axes[3].imshow(value, cmap='gray')
    axes[3].set_title("Value Channel")
    axes[3].axis("off")
    plt.show()


show_hsv_channels("images/ex3.jpg")
