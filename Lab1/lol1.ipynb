#part 3
def show_image_and_hist(path):
    img = io.imread(path)
    gray = color.rgb2gray(img)
    
    fig, axes = plt.subplots(1, 2, figsize=(12, 5))
    axes[0].imshow(gray, cmap='gray')
    axes[0].set_title("Grayscale Image")
    axes[0].axis("off")
    
    axes[1].hist(gray.ravel(), bins=256, range=[0,1], color='black')
    axes[1].set_title("Histogram")
    axes[1].set_xlabel("Intensity")
    axes[1].set_ylabel("Pixel Count")
    plt.show()

show_image_and_hist("images/ex1.png")
show_image_and_hist("images/ex2.jpg")
show_image_and_hist("images/ex3.jpg")

def create_uniform_image():
    
    uniform_image = np.tile(np.linspace(0, 1, 256), (256, 1))
    
    fig, axes = plt.subplots(1, 2, figsize=(12, 5))
    axes[0].imshow(uniform_image, cmap='gray')
    axes[0].set_title("Grayscale Image with Uniform Histogram")
    axes[0].axis("off")
    
    axes[1].hist(uniform_image.ravel(), bins=256, range=[0,1], color='black')
    axes[1].set_title("Uniform Histogram")
    axes[1].set_xlabel("Intensity")
    axes[1].set_ylabel("Pixel Count")
    plt.show()

create_uniform_image()

